{
  "$schema": "kb-engine-api-v1",
  "agent_type": "dm_crf",
  "mvp_priority": "MUST",
  "endpoints": [
    {
      "id": "DM-001",
      "name": "execution-rules",
      "method": "POST",
      "path": "/api/v1/kb/dm/execution-rules",
      "description": "Given task type, phase, and therapeutic area, return applicable Execution Rules with mandatory injection instruction. Rules MUST be injected into Agent system prompt.",
      "x_sla": {
        "p95_ms": 500
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "task_type": {
            "type": "string",
            "required": true,
            "description": "DM task type triggering rule lookup",
            "enum": [
              "crf_design",
              "data_validation",
              "coding",
              "query_management",
              "database_lock"
            ]
          },
          "phase": {
            "type": "string",
            "required": true,
            "description": "Clinical trial phase",
            "enum": [
              "Phase_I",
              "Phase_I_II",
              "Phase_II",
              "Phase_II_III",
              "Phase_III",
              "Phase_IV"
            ]
          },
          "ta": {
            "type": "string",
            "required": true,
            "description": "Therapeutic area (e.g., Oncology, CNS, Cardiology)"
          },
          "therapeutic_modality": {
            "type": "string",
            "required": false,
            "description": "Drug modality for modality-specific rules"
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "results": {
            "type": "object",
            "properties": {
              "mandatory_rules": {
                "type": "array",
                "description": "Rules that MUST be followed — injected into Agent prompt",
                "items": {
                  "type": "object",
                  "properties": {
                    "rule_id": {
                      "type": "string",
                      "description": "Rule identifier (e.g., R1, R3)"
                    },
                    "rule": {
                      "type": "string",
                      "description": "Full rule text"
                    },
                    "source": {
                      "type": "string",
                      "description": "Source reference (e.g., CDASHIG v2.2 Section 4.3)"
                    },
                    "knowledge_type": {
                      "type": "string",
                      "enum": [
                        "execution-rule"
                      ],
                      "description": "Always execution-rule"
                    },
                    "injection_priority": {
                      "type": "integer",
                      "description": "Priority order for prompt injection (1 = highest)"
                    },
                    "trust_metadata": {
                      "type": "object",
                      "properties": {
                        "trust_level": {
                          "type": "string",
                          "enum": [
                            "verified",
                            "reference",
                            "unverified",
                            "stale"
                          ]
                        },
                        "verification_level": {
                          "type": "string",
                          "enum": [
                            "L0",
                            "L1",
                            "L2",
                            "L3"
                          ]
                        },
                        "source_tier": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 4
                        },
                        "last_verified": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              },
              "recommended_rules": {
                "type": "array",
                "description": "Rules that SHOULD be followed unless Protocol overrides",
                "items": {
                  "type": "object",
                  "properties": {
                    "rule_id": {
                      "type": "string"
                    },
                    "rule": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string"
                    },
                    "knowledge_type": {
                      "type": "string",
                      "enum": [
                        "execution-rule"
                      ]
                    }
                  }
                }
              },
              "injection_instruction": {
                "type": "string",
                "description": "Mandatory instruction text — Agent must inject all mandatory_rules into system prompt"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "properties": {
              "data_completeness": {
                "type": "string"
              },
              "last_updated": {
                "type": "string",
                "format": "date-time"
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "normal",
              "elevated",
              "critical"
            ]
          },
          "log_id": {
            "type": "string"
          },
          "trust_metadata": {
            "trust_level": {
              "type": "string",
              "enum": [
                "verified",
                "reference",
                "unverified",
                "stale"
              ],
              "description": "Discrete trust level for MVP"
            },
            "verification_level": {
              "type": "string",
              "enum": [
                "L0",
                "L1",
                "L2",
                "L3"
              ],
              "description": "Highest verification level passed"
            },
            "source_tier": {
              "type": "integer",
              "enum": [
                1,
                2,
                3,
                4
              ],
              "description": "Evidence tier (1=Binding, 4=Experiential)"
            },
            "last_verified": {
              "type": "string",
              "format": "date-time",
              "description": "ISO8601 timestamp of last verification"
            }
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      },
      "access_control": {
        "allowed_agents": [
          "dm_crf",
          "learner",
          "reviewer",
          "helix",
          "convergence",
          "boss"
        ],
        "permission_level": "L1_read"
      }
    },
    {
      "id": "DM-002",
      "name": "crf-template",
      "method": "POST",
