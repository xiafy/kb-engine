                            "type": "object",
                            "properties": {
                              "code": {
                                "type": "string"
                              },
                              "decode": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    },
                    "sdtm_mapping": {
                      "type": "string",
                      "description": "Corresponding SDTM variable for mapping"
                    },
                    "collection_notes": {
