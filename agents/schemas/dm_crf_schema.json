    {
      "id": "DM-003",
      "name": "cdashig-query",
      "method": "POST",
      "path": "/api/v1/kb/dm/cdashig-query",
      "description": "Given a CDASH domain and optional variable name, return CDASHIG standard definitions, codelists, and mapping notes.",
      "x_sla": {
        "p95_ms": 500
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
