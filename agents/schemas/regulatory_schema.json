            "type": "object",
            "required": true,
            "description": "Comprehensive drug profile for pathway determination",
            "properties": {
              "drug_name": {
                "type": "string",
                "required": true,
                "description": "Drug name or code"
              },
              "therapeutic_modality": {
                "type": "string",
                "required": true,
                "description": "Modality (small_molecule, monoclonal_antibody, cell_therapy, gene_therapy, rna_therapeutic, combination)"
              },
              "mechanism": {
                "type": "string",
                "required": true,
                "description": "Mechanism of action"
              },
              "indication": {
                "type": "string",
                "required": true,
                "description": "Target indication"
              },
              "development_phase": {
                "type": "string",
                "required": true,
                "description": "Current development phase"
              },
              "is_first_in_class": {
                "type": "boolean",
                "required": false,
                "description": "Whether drug is first-in-class"
              },
              "orphan_eligible": {
                "type": "boolean",
                "required": false,
                "description": "Whether orphan drug designation may apply"
              },
              "serious_condition": {
                "type": "boolean",
                "required": false,
                "description": "Whether indication is a serious/life-threatening condition"
              },
              "unmet_need": {
                "type": "boolean",
                "required": false,
                "description": "Whether there is substantial unmet medical need"
              }
            }
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "results": {
            "type": "object",
            "properties": {
              "recommended_pathway": {
                "type": "string",
                "description": "Primary recommended regulatory pathway",
                "enum": [
                  "NDA_505b1",
                  "NDA_505b2",
                  "BLA",
                  "510k",
                  "PMA",
                  "De_Novo"
                ]
              },
              "rationale": {
                "type": "string",
                "description": "Detailed rationale for the recommendation"
              },
              "alternative_pathways": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "pathway": {
                      "type": "string"
                    },
                    "rationale": {
                      "type": "string"
                    },
                    "trade_offs": {
                      "type": "string"
                    }
                  }
                }
              },
              "expedited_programs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "program": {
                      "type": "string",
                      "enum": [
                        "Fast_Track",
                        "Breakthrough_Therapy",
                        "Accelerated_Approval",
                        "Priority_Review",
                        "RMAT"
                      ]
                    },
                    "eligibility_assessment": {
                      "type": "string",
                      "enum": [
                        "likely_eligible",
                        "potentially_eligible",
                        "unlikely_eligible"
                      ]
                    },
                    "rationale": {
                      "type": "string"
                    }
                  }
                }
              },
              "regulatory_requirements": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Key regulatory requirements for the recommended pathway"
              },
              "precedents": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "drug_name": {
                      "type": "string"
                    },
                    "pathway_used": {
                      "type": "string"
                    },
                    "approval_year": {
                      "type": "integer"
                    },
                    "similarity_note": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "trust_metadata": {
            "type": "object",
            "properties": {
              "trust_level": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified",
                  "stale"
                ]
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ]
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4
              },
              "last_verified": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "properties": {
              "data_completeness": {
                "type": "string"
              },
              "last_updated": {
                "type": "string",
                "format": "date-time"
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "elevated"
            ]
          },
          "log_id": {
            "type": "string"
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      },
      "access_control": {
        "allowed_agents": [
          "regulatory",
          "learner",
          "reviewer",
          "helix",
          "convergence",
          "boss"
        ],
        "permission_level": "L1_read"
      }
    }
  ]
}