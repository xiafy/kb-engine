{
  "$schema": "kb-engine-api-v1",
  "agent_type": "regulatory",
  "mvp_priority": "MUST",
  "endpoints": [
    {
      "id": "REG-001",
      "name": "guidance-match",
      "method": "POST",
      "path": "/api/v1/kb/regulatory/guidance-match",
      "description": "Given indication, mechanism, and submission type, return a ranked list of applicable FDA Guidance documents with evidence tier, trust metadata, and coverage statement.",
      "x_sla": {
        "p95_ms": 2000
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "description": "Optional shared context for query enrichment",
            "properties": {
              "indication": {
                "type": "string",
                "required": false,
                "description": "Disease indication (e.g., NSCLC)"
              },
              "phase": {
                "type": "string",
                "required": false,
                "description": "Development phase (e.g., Phase III)"
              },
              "ta": {
                "type": "string",
                "required": false,
                "description": "Therapeutic area (e.g., Oncology)"
              },
              "submission_type": {
                "type": "string",
                "required": false,
                "description": "Submission type (e.g., NDA, BLA)"
              }
            }
          },
          "indication": {
            "type": "string",
            "required": true,
            "description": "Target disease indication (e.g., NSCLC, melanoma)"
          },
          "mechanism": {
            "type": "string",
            "required": true,
            "description": "Drug mechanism of action (e.g., anti-PD-1, EGFR TKI)"
          },
          "submission_type": {
            "type": "string",
            "required": true,
            "description": "Regulatory submission type",
            "enum": [
              "NDA",
              "BLA",
              "510k",
              "PMA",
              "EUA",
              "ANDA"
            ]
          },
          "context_date": {
            "type": "string",
            "required": false,
            "format": "date",
            "description": "Bi-temporal query date — returns guidance valid at this date (ISO8601)"
          },
          "output": {
            "type": "object",
            "required": false,
            "description": "Output format preferences",
            "properties": {
              "format": {
                "type": "string",
                "enum": [
                  "structured",
                  "summary"
                ],
                "description": "Response format"
              },
              "max_tokens": {
                "type": "integer",
                "description": "Maximum tokens for summary fields"
              },
              "include_trust_metadata": {
                "type": "boolean",
                "description": "Include trust metadata in response"
              },
              "include_coverage": {
                "type": "boolean",
                "description": "Include coverage statement in response"
              }
            }
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string",
            "description": "Unique request identifier"
          },
          "results": {
            "type": "array",
            "description": "Ranked list of applicable guidance documents",
            "items": {
              "type": "object",
              "properties": {
                "guidance_id": {
                  "type": "string",
                  "description": "FDA Guidance document ID (e.g., FDA-2023-D-0045)"
                },
                "title": {
                  "type": "string",
                  "description": "Full title of the guidance document"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "Draft",
                    "Final",
                    "Withdrawn"
                  ],
                  "description": "Current regulatory status"
                },
                "effective_date": {
                  "type": "string",
                  "format": "date",
                  "description": "Date the guidance became effective"
                },
                "evidence_tier": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 4,
                  "description": "Evidence classification: 1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
                },
                "key_facts": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Key takeaways relevant to the query context"
                },
                "relevance_score": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Semantic relevance to the query"
                },
                "trust_metadata": {
                  "type": "object",
                  "properties": {
                    "trust_level": {
                      "type": "string",
                      "enum": [
                        "verified",
                        "reference",
                        "unverified",
                        "stale"
                      ]
                    },
                    "verification_level": {
                      "type": "string",
                      "enum": [
                        "L0",
                        "L1",
                        "L2",
                        "L3"
                      ]
                    },
                    "source_tier": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 4
                    },
                    "last_verified": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                },
                "detail_ref": {
                  "type": "string",
                  "format": "uri",
                  "description": "URI to full document content via PUB-001"
                }
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "properties": {
              "data_completeness": {
                "type": "string",
                "description": "Coverage summary"
              },
              "last_updated": {
                "type": "string",
                "format": "date-time"
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "normal",
              "elevated",
              "critical"
            ],
            "description": "Endpoint risk classification"
          },
          "log_id": {
            "type": "string",
            "description": "Retrieval log identifier for audit trail"
          },
          "trust_metadata": {
            "trust_level": {
              "type": "string",
              "enum": [
                "verified",
                "reference",
                "unverified",
                "stale"
              ],
              "description": "Discrete trust level for MVP"
            },
            "verification_level": {
              "type": "string",
              "enum": [
                "L0",
                "L1",
                "L2",
                "L3"
              ],
              "description": "Highest verification level passed"
            },
            "source_tier": {
              "type": "integer",
              "enum": [
                1,
                2,
                3,
                4
              ],
              "description": "Evidence tier (1=Binding, 4=Experiential)"
            },
            "last_verified": {
              "type": "string",
              "format": "date-time",
              "description": "ISO8601 timestamp of last verification"
            }
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      },
      "access_control": {
        "allowed_agents": [
          "regulatory",
          "learner",
          "reviewer",
          "helix",
          "convergence",
          "boss"
        ],
        "permission_level": "L1_read"
      }
    },
    {
      "id": "REG-002",
      "name": "review-precedent",
