    {
      "id": "REG-003",
      "name": "ectd-check",
      "method": "POST",
      "path": "/api/v1/kb/regulatory/ectd-check",
      "description": "Given a list of eCTD modules present, perform gap analysis and identify missing required/conditional modules for the submission type.",
      "x_sla": {
        "p95_ms": 500
      },
      "x_risk_level": "critical",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "ectd_module_list": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "required": true,
            "description": "List of eCTD module numbers present (e.g., ['1.1', '1.2', '2.3', '2.5', '5.3.5'])"
          },
          "submission_type": {
            "type": "string",
            "required": true,
            "description": "Submission type to validate against",
            "enum": [
              "NDA",
              "BLA",
              "ANDA",
              "IND"
            ]
          },
          "indication": {
            "type": "string",
            "required": false,
            "description": "Indication for conditional module requirements"
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "results": {
            "type": "object",
            "properties": {
              "completeness_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Overall completeness ratio"
              },
              "total_required": {
                "type": "integer",
                "description": "Total number of required modules for this submission type"
              },
              "total_present": {
                "type": "integer",
                "description": "Number of required modules present"
              },
              "missing_required": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "module": {
                      "type": "string",
                      "description": "Module number (e.g., 2.4)"
                    },
                    "name": {
                      "type": "string",
                      "description": "Module name"
                    },
                    "requirement": {
                      "type": "string",
                      "enum": [
                        "mandatory",
                        "conditional"
                      ],
                      "description": "Whether module is always required or conditional"
                    },
                    "condition": {
                      "type": "string",
                      "description": "Condition under which this module is required (if conditional)"
                    }
                  }
                }
              },
              "recommendations": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Actionable recommendations for addressing gaps"
              }
            }
          },
          "trust_metadata": {
            "type": "object",
            "properties": {
              "trust_level": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified",
                  "stale"
                ]
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ]
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4
              },
              "last_verified": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "properties": {
              "data_completeness": {
                "type": "string"
              },
              "last_updated": {
                "type": "string",
                "format": "date-time"
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "critical"
            ]
          },
          "requires_verification": {
            "type": "boolean",
            "description": "Always true for eCTD completeness checks"
          },
          "verification_reason": {
            "type": "string",
            "description": "Reason verification is required"
          },
          "log_id": {
            "type": "string"
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      },
      "access_control": {
        "allowed_agents": [
          "regulatory",
          "learner",
          "reviewer",
          "helix",
          "convergence",
          "boss"
        ],
        "permission_level": "L1_read"
      }
    },
