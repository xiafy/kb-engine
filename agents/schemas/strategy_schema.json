{
  "$schema": "kb-engine-api-v1",
  "agent_type": "strategy",
  "mvp_priority": "SHOULD",
  "endpoints": [
    {
      "id": "STR-001",
      "name": "competitive-landscape",
      "method": "POST",
      "path": "/api/v1/kb/strategy/competitive-landscape",
      "description": "Given indication, mechanism, and year range, return a competitive comparison table of approved/in-development drugs with key clinical metrics.",
      "x_sla": {
        "p95_ms": 2000
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "indication": {
            "type": "string",
            "required": true,
            "description": "Target indication (e.g., NSCLC, melanoma)"
          },
          "mechanism": {
            "type": "string",
            "required": true,
            "description": "Drug mechanism class (e.g., anti-PD-1/PD-L1, EGFR TKI)"
          },
          "year_range": {
            "type": "object",
            "required": false,
            "properties": {
              "start": {
                "type": "integer",
                "description": "Start year (inclusive)"
              },
              "end": {
                "type": "integer",
                "description": "End year (inclusive)"
              }
            }
          },
          "output": {
            "type": "object",
            "required": false,
            "properties": {
              "format": {
                "type": "string",
                "enum": [
                  "comparison_table",
                  "structured",
                  "summary"
                ]
              },
              "max_tokens": {
                "type": "integer"
              }
            }
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "results": {
            "type": "object",
            "properties": {
              "total_products": {
                "type": "integer",
                "description": "Total number of matching products"
              },
              "comparison_table": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "drug_name": {
                      "type": "string"
                    },
                    "sponsor": {
                      "type": "string"
                    },
                    "nda_bla_number": {
                      "type": "string"
                    },
                    "approval_date": {
                      "type": "string",
                      "format": "date"
                    },
                    "development_phase": {
                      "type": "string"
                    },
                    "primary_endpoint": {
                      "type": "string"
                    },
                    "pivotal_trial": {
                      "type": "string"
                    },
                    "key_efficacy_metrics": {
                      "type": "object",
                      "properties": {
                        "os_hr": {
                          "type": "number",
                          "description": "OS hazard ratio"
                        },
                        "pfs_months": {
                          "type": "number",
                          "description": "Median PFS in months"
                        },
                        "orr_percent": {
                          "type": "number",
                          "description": "Overall response rate %"
                        },
                        "dor_months": {
                          "type": "number",
                          "description": "Median duration of response in months"
                        }
                      }
                    },
                    "key_label_claims": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "expedited_programs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Granted expedited programs (Fast Track, Breakthrough, etc.)"
                    }
                  }
                }
              }
            }
          },
          "trust_metadata": {
            "type": "object",
            "description": "Trust metadata. verification_status = knowledge validation state; freshness_status = temporal currency.",
            "properties": {
              "verification_status": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified"
                ],
                "description": "verified (L2+ confirmed), reference (L1 auto-verified), unverified (L0 only)"
              },
              "freshness_status": {
                "type": "string",
                "enum": [
                  "fresh",
                  "aging",
                  "stale",
                  "expired"
                ],
                "description": "fresh (<max_days), aging (approaching review date), stale (past review date), expired (exceeds max_days)"
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4,
                "description": "1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ],
                "description": "L0=source hash, L1=auto-rules, L2=human/cross-source, L3=external audit"
              },
              "last_verified": {
                "type": "string",
                "format": "date",
                "description": "Date of last verification"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "description": "Data completeness declaration.",
            "properties": {
              "description": {
                "type": "string",
                "description": "Human-readable coverage description"
              },
              "coverage_ratio": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Quantified coverage (0-1)"
              },
              "total_available": {
                "type": "integer",
                "description": "Relevant items in KB"
              },
              "total_estimated": {
                "type": "integer",
                "description": "Estimated total relevant items"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "exact",
                  "estimated",
                  "unknown"
                ]
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Known data gaps"
              },
              "last_updated": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "normal",
              "elevated",
              "critical"
            ]
          },
          "log_id": {
            "type": "string"
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      }
    },
