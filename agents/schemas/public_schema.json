      "x_sla": {
        "p95_ms": 200
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "concept_id": {
            "type": "string",
            "required": true,
            "description": "Core Ontology concept ID (path parameter, e.g., CO-REG-001)"
          },
          "context_date": {
            "type": "string",
            "required": false,
            "format": "date",
            "description": "Bi-temporal query — returns concept valid at this date"
