{
  "$schema": "kb-engine-api-v1",
  "agent_type": "public",
  "mvp_priority": "MUST",
  "endpoints": [
    {
      "id": "PUB-001",
      "name": "document-detail",
      "method": "GET",
      "path": "/api/v1/kb/document/{doc_id}",
      "description": "Retrieve full document content and metadata by document ID. This is the implementation of detail_ref URIs returned by domain APIs.",
      "x_sla": {
        "p95_ms": 500
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier (passed as query parameter or header)"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "doc_id": {
            "type": "string",
            "required": true,
            "description": "Document identifier (path parameter, e.g., FDA-2023-D-0045)"
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "required": false,
            "description": "Optional: specific sections to retrieve (if omitted, returns full document)"
          },
          "include_raw": {
            "type": "boolean",
            "required": false,
            "description": "Whether to include the raw/original text alongside structured content"
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "doc_id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "description": "Document title"
          },
          "full_content": {
            "type": "string",
            "description": "Full document content (markdown or structured text)"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "document_type": {
                "type": "string",
                "description": "Document classification (e.g., fda_guidance, fda_review, protocol, csr)"
              },
              "status": {
                "type": "string",
                "enum": [
                  "Draft",
                  "Final",
                  "Withdrawn",
                  "Superseded"
                ]
              },
              "effective_date": {
                "type": "string",
                "format": "date"
              },
              "sha256": {
                "type": "string",
                "description": "SHA-256 hash of the immutable source"
              },
              "source_url": {
                "type": "string",
                "format": "uri",
                "description": "Original source URL"
              },
              "page_count": {
                "type": "integer"
              },
              "ingestion_date": {
                "type": "string",
                "format": "date-time"
              },
              "evidence_category": {
                "type": "string",
                "enum": [
                  "Binding",
                  "Authoritative",
                  "Informative",
                  "Experiential"
                ]
              },
              "knowledge_type": {
                "type": "string",
                "enum": [
                  "execution-rule",
                  "reference",
                  "template"
                ]
              },
              "facets": {
                "type": "object",
                "properties": {
                  "document_type": {
                    "type": "string"
                  },
                  "regulatory_pathway": {
                    "type": "string"
                  },
                  "development_phase": {
                    "type": "string"
                  },
                  "therapeutic_modality": {
                    "type": "string"
                  },
                  "clinical_domain": {
                    "type": "string"
                  },
                  "evidence_category": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "trust_metadata": {
            "type": "object",
            "description": "Trust metadata. verification_status = knowledge validation state; freshness_status = temporal currency.",
            "properties": {
              "verification_status": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified"
                ],
                "description": "verified (L2+ confirmed), reference (L1 auto-verified), unverified (L0 only)"
              },
              "freshness_status": {
                "type": "string",
                "enum": [
                  "fresh",
                  "aging",
                  "stale",
                  "expired"
                ],
                "description": "fresh (<max_days), aging (approaching review date), stale (past review date), expired (exceeds max_days)"
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4,
                "description": "1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ],
                "description": "L0=source hash, L1=auto-rules, L2=human/cross-source, L3=external audit"
              },
              "last_verified": {
                "type": "string",
                "format": "date",
                "description": "Date of last verification"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "description": "Data completeness declaration.",
            "properties": {
              "description": {
                "type": "string",
                "description": "Human-readable coverage description"
              },
              "coverage_ratio": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Quantified coverage (0-1)"
              },
              "total_available": {
                "type": "integer",
                "description": "Relevant items in KB"
              },
              "total_estimated": {
                "type": "integer",
                "description": "Estimated total relevant items"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "exact",
                  "estimated",
                  "unknown"
                ]
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Known data gaps"
              },
              "last_updated": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "normal",
              "elevated",
              "critical"
            ]
          },
          "log_id": {
            "type": "string"
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      }
    },
    {
      "id": "PUB-002",
      "name": "concept-lookup",
      "method": "GET",
