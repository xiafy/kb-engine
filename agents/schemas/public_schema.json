    {
      "id": "PUB-003",
      "name": "search",
      "method": "POST",
      "path": "/api/v1/kb/search",
      "description": "Universal cross-domain search combining semantic retrieval, structured filtering, and numerical assertion lookup. Supports all four retrieval channels. Supports batch queries (string[] for multiple queries in one request, max 10).",
      "x_sla": {
        "p95_ms": 5000
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "query": {
            "oneOf": [
              {
                "type": "string",
                "description": "Single search query"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Batch queries (max 10), returns grouped results per query"
              }
            ],
            "required": true,
            "description": "Search query. String for single query, array for batch (max 10). Batch returns results grouped by query index."
          },
          "filters": {
            "type": "object",
            "required": false,
            "description": "Structured filters for faceted search",
            "properties": {
              "document_type": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Filter by document type (e.g., fda_guidance, fda_review, protocol, csr)"
              },
              "evidence_category": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "Binding",
                    "Authoritative",
                    "Informative",
                    "Experiential"
                  ]
                }
              },
              "knowledge_type": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "execution-rule",
                    "reference",
                    "template"
                  ]
                }
              },
              "date_range": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "date"
                },
                "description": "Date range filter [start, end]"
              },
              "therapeutic_area": {
                "type": "string"
              },
              "development_phase": {
                "type": "string"
              },
              "regulatory_pathway": {
                "type": "string"
              },
              "min_trust_level": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified",
                  "stale"
                ],
                "description": "Minimum trust level filter"
              }
            }
          },
          "limit": {
            "type": "integer",
            "required": false,
            "description": "Maximum results to return",
            "default": 20,
            "maximum": 100
          },
          "offset": {
            "type": "integer",
            "required": false,
            "description": "Pagination offset",
            "default": 0
          },
          "include_trust_metadata": {
            "type": "boolean",
            "required": false,
            "description": "Include trust metadata per result",
            "default": true
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "total_hits": {
            "type": "integer",
            "description": "Total matching results"
          },
          "results": {
            "type": "array",
