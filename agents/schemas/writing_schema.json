{
  "$schema": "kb-engine-api-v1",
  "agent_type": "writing",
  "mvp_priority": "SHOULD",
  "endpoints": [
    {
      "id": "WRT-001",
      "name": "template-retrieve",
      "method": "POST",
      "path": "/api/v1/kb/writing/template-retrieve",
      "description": "Given document type, therapeutic area, and phase, return the applicable document template structure with section list, guidance notes, and execution rules.",
      "x_sla": {
        "p95_ms": 500
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "document_type": {
            "type": "string",
            "required": true,
            "description": "Type of clinical document",
            "enum": [
              "protocol",
              "csr",
              "csr_synopsis",
              "ib",
              "sap",
              "icf",
              "dsur",
              "pbrer",
              "ctd_summary"
            ]
          },
          "ta": {
            "type": "string",
            "required": true,
            "description": "Therapeutic area"
          },
          "phase": {
            "type": "string",
            "required": true,
            "description": "Development phase",
            "enum": [
              "Phase_I",
              "Phase_I_II",
              "Phase_II",
              "Phase_II_III",
              "Phase_III",
              "Phase_IV",
              "NDA_BLA"
            ]
          },
          "indication": {
            "type": "string",
            "required": false,
            "description": "Specific indication for template refinement"
          },
          "ectd_module": {
            "type": "string",
            "required": false,
            "description": "eCTD module reference (e.g., 5.3.5.1)"
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "results": {
            "type": "object",
            "properties": {
              "template_id": {
                "type": "string",
                "description": "Template identifier (e.g., TPL-PROTO-ONCO-P3-v1.2)"
              },
              "template_version": {
                "type": "string"
              },
              "document_type": {
                "type": "string"
              },
              "template_structure": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "section": {
                      "type": "string",
                      "description": "Section number (e.g., 1.0, 2.1)"
                    },
                    "title": {
                      "type": "string",
                      "description": "Section title"
                    },
                    "guidance_notes": {
                      "type": "string",
                      "description": "Writing guidance for this section"
                    },
                    "is_mandatory": {
                      "type": "boolean"
                    },
                    "typical_length": {
                      "type": "string",
                      "description": "Expected length range (e.g., 1-2 pages)"
                    },
                    "execution_rules": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Applicable execution rules for this section"
                    },
                    "subsections": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "section": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "guidance_notes": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              },
              "similar_precedents": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "drug_name": {
                      "type": "string"
                    },
                    "document_title": {
                      "type": "string"
                    },
                    "detail_ref": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                }
              },
              "regulatory_requirements": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Key regulatory requirements for this document type"
              }
            }
          },
          "trust_metadata": {
            "type": "object",
            "description": "Trust metadata. verification_status = knowledge validation state; freshness_status = temporal currency.",
            "properties": {
              "verification_status": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified"
                ],
                "description": "verified (L2+ confirmed), reference (L1 auto-verified), unverified (L0 only)"
              },
              "freshness_status": {
                "type": "string",
                "enum": [
                  "fresh",
                  "aging",
                  "stale",
                  "expired"
                ],
                "description": "fresh (<max_days), aging (approaching review date), stale (past review date), expired (exceeds max_days)"
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4,
                "description": "1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ],
                "description": "L0=source hash, L1=auto-rules, L2=human/cross-source, L3=external audit"
              },
              "last_verified": {
                "type": "string",
                "format": "date",
                "description": "Date of last verification"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "description": "Data completeness declaration.",
            "properties": {
              "description": {
                "type": "string",
                "description": "Human-readable coverage description"
              },
              "coverage_ratio": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Quantified coverage (0-1)"
              },
              "total_available": {
                "type": "integer",
                "description": "Relevant items in KB"
              },
              "total_estimated": {
                "type": "integer",
                "description": "Estimated total relevant items"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "exact",
                  "estimated",
                  "unknown"
                ]
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Known data gaps"
              },
              "last_updated": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "normal",
              "elevated",
              "critical"
            ]
          },
          "log_id": {
            "type": "string"
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      }
    },
