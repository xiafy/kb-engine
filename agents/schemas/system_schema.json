{
  "$schema": "kb-engine-api-v1",
  "agent_type": "system",
  "mvp_priority": "MUST",
  "endpoints": [
    {
      "id": "SYS-001",
      "name": "rules-push",
      "method": "POST",
      "path": "/api/v1/kb/rules/push",
      "description": "Push Execution Rules to an Agent based on task_type. System-level internal call triggered when an Agent starts a task. Returns all mandatory rules that MUST be injected into the Agent's system prompt.",
      "x_sla": {
        "p95_ms": 100
      },
      "x_risk_level": "elevated",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "ID of the Agent receiving the rules"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "task_type": {
            "type": "string",
            "required": true,
            "description": "Task type triggering rule push",
            "enum": [
              "crf_design",
              "protocol_writing",
              "csr_writing",
              "sap_generation",
              "nda_checklist",
              "ectd_review",
              "data_validation",
              "safety_review",
              "pk_analysis"
            ]
          },
          "agent_type": {
            "type": "string",
            "required": false,
            "description": "Type of the receiving Agent for rule filtering"
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "rules_count": {
            "type": "integer",
            "description": "Total number of rules pushed"
          },
          "mandatory_rules": {
            "type": "array",
            "description": "Rules that MUST be injected into Agent system prompt — skipping any rule is a compliance violation",
            "items": {
              "type": "object",
              "properties": {
                "rule_id": {
                  "type": "string",
                  "description": "Rule identifier"
                },
                "rule": {
                  "type": "string",
                  "description": "Full rule text"
                },
                "injection_priority": {
                  "type": "integer",
                  "description": "Injection order priority (1 = highest)"
                },
                "source": {
                  "type": "string",
                  "description": "Source reference"
                },
                "scope": {
                  "type": "string",
                  "description": "Scope of applicability (e.g., all_phases, phase_i_only)"
                },
                "trust_metadata": {
                  "type": "object",
                  "description": "Trust metadata. verification_status = knowledge validation state; freshness_status = temporal currency.",
                  "properties": {
                    "verification_status": {
                      "type": "string",
                      "enum": [
                        "verified",
                        "reference",
                        "unverified"
                      ],
                      "description": "verified (L2+ confirmed), reference (L1 auto-verified), unverified (L0 only)"
                    },
                    "freshness_status": {
                      "type": "string",
                      "enum": [
                        "fresh",
                        "aging",
                        "stale",
                        "expired"
                      ],
                      "description": "fresh (<max_days), aging (approaching review date), stale (past review date), expired (exceeds max_days)"
                    },
                    "source_tier": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 4,
                      "description": "1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
                    },
                    "verification_level": {
                      "type": "string",
                      "enum": [
                        "L0",
                        "L1",
                        "L2",
                        "L3"
                      ],
                      "description": "L0=source hash, L1=auto-rules, L2=human/cross-source, L3=external audit"
                    },
                    "last_verified": {
                      "type": "string",
                      "format": "date",
                      "description": "Date of last verification"
                    }
                  }
                }
              }
            }
          },
          "injection_instruction": {
            "type": "string",
            "description": "Mandatory instruction — all rules MUST be injected before task execution"
          },
          "coverage_statement": {
            "type": "object",
            "description": "Data completeness declaration.",
            "properties": {
              "description": {
                "type": "string",
                "description": "Human-readable coverage description"
              },
              "coverage_ratio": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Quantified coverage (0-1)"
              },
              "total_available": {
                "type": "integer",
                "description": "Relevant items in KB"
              },
              "total_estimated": {
                "type": "integer",
                "description": "Estimated total relevant items"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "exact",
                  "estimated",
                  "unknown"
                ]
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Known data gaps"
              },
              "last_updated": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "elevated"
            ]
          },
          "log_id": {
            "type": "string"
          },
          "trust_metadata": {
            "type": "object",
            "description": "Trust metadata. verification_status = knowledge validation state; freshness_status = temporal currency.",
            "properties": {
              "verification_status": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified"
                ],
                "description": "verified (L2+ confirmed), reference (L1 auto-verified), unverified (L0 only)"
              },
              "freshness_status": {
                "type": "string",
                "enum": [
                  "fresh",
                  "aging",
                  "stale",
                  "expired"
                ],
                "description": "fresh (<max_days), aging (approaching review date), stale (past review date), expired (exceeds max_days)"
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4,
                "description": "1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ],
                "description": "L0=source hash, L1=auto-rules, L2=human/cross-source, L3=external audit"
              },
              "last_verified": {
                "type": "string",
                "format": "date",
                "description": "Date of last verification"
              }
            }
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      }
    },
    {
      "id": "SYS-002",
      "name": "feedback",
      "method": "POST",
      "path": "/api/v1/kb/feedback",
      "description": "Submit correction or feedback about KB content. Creates a task for KB Convergence Agent to process. All agents can submit feedback — this is the reverse convergence channel.",
      "x_sla": {
        "p95_ms": 500
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
