          },
          "estimated_resolution": {
            "type": "string",
            "description": "Estimated resolution timeline (e.g., next_convergence_cycle, immediate)"
          },
          "trust_metadata": {
            "type": "object",
            "description": "Trust metadata. verification_status = knowledge validation state; freshness_status = temporal currency.",
            "properties": {
              "verification_status": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified"
                ],
                "description": "verified (L2+ confirmed), reference (L1 auto-verified), unverified (L0 only)"
              },
              "freshness_status": {
                "type": "string",
                "enum": [
                  "fresh",
                  "aging",
                  "stale",
                  "expired"
                ],
                "description": "fresh (<max_days), aging (approaching review date), stale (past review date), expired (exceeds max_days)"
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4,
                "description": "1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ],
                "description": "L0=source hash, L1=auto-rules, L2=human/cross-source, L3=external audit"
              },
              "last_verified": {
                "type": "string",
                "format": "date",
                "description": "Date of last verification"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "description": "Data completeness declaration.",
            "properties": {
              "description": {
                "type": "string",
                "description": "Human-readable coverage description"
              },
              "coverage_ratio": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Quantified coverage (0-1)"
              },
              "total_available": {
                "type": "integer",
                "description": "Relevant items in KB"
              },
              "total_estimated": {
                "type": "integer",
                "description": "Estimated total relevant items"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "exact",
                  "estimated",
                  "unknown"
                ]
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Known data gaps"
              },
              "last_updated": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "normal",
              "elevated",
              "critical"
            ]
          },
          "log_id": {
            "type": "string"
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      }
    },
    {
      "id": "SYS-003",
      "name": "verify",
      "method": "POST",
      "path": "/api/v1/kb/verify",
      "description": "Submit verification results for KB content. Used by Learner (write-verify separation: cannot verify own writes) and REVIEWER (marks review opinions, does not directly update trust_score).",
      "x_sla": {
        "p95_ms": 500
      },
      "x_risk_level": "normal",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "target_id": {
            "type": "string",
            "required": true,
            "description": "ID of the KB content being verified"
          },
          "verification_type": {
            "type": "string",
            "required": true,
            "description": "Type of verification performed",
            "enum": [
