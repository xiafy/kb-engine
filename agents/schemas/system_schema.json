    {
      "id": "SYS-004",
      "name": "ingest",
      "method": "POST",
      "path": "/api/v1/kb/ingest",
      "description": "Ingest new knowledge into KB. Content passes through Ingestion Quality Gate (L0-L3) before being stored. PM LRN sub-agent has restricted access (common/ and cro-internal/ only, new files only, reference type only).",
      "x_sla": {
        "p95_ms": 5000
      },
      "x_risk_level": "elevated",
      "request": {
        "content_type": "application/json",
        "body": {
          "agent_id": {
            "type": "string",
            "required": true,
            "description": "Calling agent identifier"
          },
          "context": {
            "type": "object",
            "required": false,
            "properties": {
              "indication": {
                "type": "string",
                "required": false
              },
              "phase": {
                "type": "string",
                "required": false
              },
              "ta": {
                "type": "string",
                "required": false
              },
              "submission_type": {
                "type": "string",
                "required": false
              }
            }
          },
          "content": {
            "type": "object",
            "required": true,
            "description": "The knowledge content to ingest",
            "properties": {
              "title": {
                "type": "string",
                "required": true,
                "description": "Document or knowledge entry title"
              },
              "body": {
                "type": "string",
                "required": true,
                "description": "Full content (markdown supported)"
              },
              "content_hash": {
                "type": "string",
                "required": false,
                "description": "SHA-256 hash of the original source (for Layer 1 immutability)"
              }
            }
          },
          "metadata": {
            "type": "object",
            "required": true,
            "description": "Structured metadata for the ingested content",
            "properties": {
              "document_type": {
                "type": "string",
                "required": true,
                "description": "Document classification"
              },
              "knowledge_type": {
                "type": "string",
                "required": true,
                "enum": [
                  "execution-rule",
                  "reference",
                  "template"
                ],
                "description": "Knowledge type classification"
              },
              "evidence_category": {
                "type": "string",
                "required": true,
                "enum": [
                  "Binding",
                  "Authoritative",
                  "Informative",
                  "Experiential"
                ]
              },
              "source_url": {
                "type": "string",
                "required": false,
                "format": "uri",
                "description": "Original source URL"
              },
              "source_citation": {
                "type": "string",
                "required": true,
                "description": "Full citation (PMID, NCT, FDA document number, etc.)"
              },
              "facets": {
                "type": "object",
                "properties": {
                  "document_type": {
                    "type": "string"
                  },
                  "regulatory_pathway": {
                    "type": "string"
                  },
                  "development_phase": {
                    "type": "string"
                  },
                  "therapeutic_modality": {
                    "type": "string"
                  },
                  "clinical_domain": {
                    "type": "string"
                  },
                  "evidence_category": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "target_area": {
            "type": "string",
            "required": true,
            "description": "KB storage area",
            "enum": [
              "common",
              "cro_internal",
              "sponsors"
            ]
          },
          "initial_trust_assessment": {
            "type": "object",
            "required": false,
            "description": "Initial trust metadata proposed by the ingesting agent",
            "properties": {
              "proposed_trust_level": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified"
                ]
              },
              "proposed_source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4
              },
              "verification_notes": {
                "type": "string"
              }
            }
          }
        }
      },
      "response": {
        "success": {
          "request_id": {
            "type": "string"
          },
          "ingestion_id": {
            "type": "string",
            "description": "Unique ingestion record ID"
          },
          "doc_id": {
            "type": "string",
            "description": "Assigned document ID in KB"
          },
          "status": {
            "type": "string",
            "enum": [
              "ingested",
              "ingested_unverified",
              "rejected",
              "duplicate_detected"
            ],
            "description": "Ingestion result status"
          },
          "quality_gate_results": {
            "type": "object",
            "description": "Results from the L0-L3 Ingestion Quality Gate",
            "properties": {
              "l0_source_verification": {
                "type": "object",
                "properties": {
                  "passed": {
                    "type": "boolean"
                  },
                  "details": {
                    "type": "string"
                  }
                }
              },
              "l1_metadata_completeness": {
                "type": "object",
                "properties": {
                  "passed": {
                    "type": "boolean"
                  },
                  "missing_fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "l2_semantic_consistency": {
                "type": "object",
                "properties": {
                  "passed": {
                    "type": "boolean"
                  },
                  "conflicts": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "l3_trust_assignment": {
                "type": "object",
                "properties": {
                  "assigned_trust_level": {
                    "type": "string",
                    "enum": [
                      "verified",
                      "reference",
                      "unverified"
                    ]
                  },
                  "assigned_source_tier": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 4
                  }
                }
              }
            }
          },
          "sha256": {
            "type": "string",
            "description": "SHA-256 hash of the ingested content"
          },
          "trust_metadata": {
            "type": "object",
            "description": "Trust metadata. verification_status = knowledge validation state; freshness_status = temporal currency.",
            "properties": {
              "verification_status": {
                "type": "string",
                "enum": [
                  "verified",
                  "reference",
                  "unverified"
                ],
                "description": "verified (L2+ confirmed), reference (L1 auto-verified), unverified (L0 only)"
              },
              "freshness_status": {
                "type": "string",
                "enum": [
                  "fresh",
                  "aging",
                  "stale",
                  "expired"
                ],
                "description": "fresh (<max_days), aging (approaching review date), stale (past review date), expired (exceeds max_days)"
              },
              "source_tier": {
                "type": "integer",
                "minimum": 1,
                "maximum": 4,
                "description": "1=Binding, 2=Authoritative, 3=Informative, 4=Experiential"
              },
              "verification_level": {
                "type": "string",
                "enum": [
                  "L0",
                  "L1",
                  "L2",
                  "L3"
                ],
                "description": "L0=source hash, L1=auto-rules, L2=human/cross-source, L3=external audit"
              },
              "last_verified": {
                "type": "string",
                "format": "date",
                "description": "Date of last verification"
              }
            }
          },
          "coverage_statement": {
            "type": "object",
            "description": "Data completeness declaration.",
            "properties": {
              "description": {
                "type": "string",
                "description": "Human-readable coverage description"
              },
              "coverage_ratio": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Quantified coverage (0-1)"
              },
              "total_available": {
                "type": "integer",
                "description": "Relevant items in KB"
              },
              "total_estimated": {
                "type": "integer",
                "description": "Estimated total relevant items"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "exact",
                  "estimated",
                  "unknown"
                ]
              },
              "known_gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Known data gaps"
              },
              "last_updated": {
                "type": "string",
                "format": "date"
              }
            }
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "elevated"
            ]
          },
          "log_id": {
            "type": "string"
          }
        },
        "error": {
          "$ref": "error_handling.json#/errors"
        }
      }
    }
  ]
}